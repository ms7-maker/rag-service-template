# Скопируйте в .env и заполните значения.
# Файл .env не коммитьте в git — в нём секреты.

# --- OpenAI (обязательно для RAG и оценки RAGAS) ---
# Ключ API: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Скрапер веб-страниц (render_and_clean.py) ---
# Основная страница каталога / сайта. Без URL в коде — только здесь.
SCRAPER_PAGE_URL=

# Вторая страница (необязательно). Текст добавится к основному через разделитель.
SCRAPER_PAGE_URL_2=

# Скрапер сохраняет: assistant_api/data/<домен>_clean.txt
# Например pourdebeau.ru → data/pourdebeau_clean.txt

# --- Playwright (необязательно) ---
# 1 / true — браузер без окна (по умолчанию). 0 / false — видимое окно (отладка).
PLAYWRIGHT_HEADLESS=1

# Пауза после загрузки страницы, мс (для SPA и подгрузки каталога).
PLAYWRIGHT_WAIT_MS=5000

# Таймаут перехода по URL, мс.
PLAYWRIGHT_TIMEOUT_MS=60000

# User-Agent для Chromium (необязательно). Пусто — стандартный Chrome на Windows.
# HTTP_USER_AGENT=

# Тестовый запрос для python vector_store.py (необязательно)
# VECTOR_STORE_TEST_QUERY=Какая информация содержится в базе знаний?

# --- Очистка локальных документов (cleaner.py) ---
# В терминале (приоритет над .env):
#   python cleaner.py about.docx
#   python cleaner.py data/raw/catalog.pdf
# Или в .env — файл, несколько через запятую или папка:
# CLEANER_INPUT_PATH=data/raw/about.docx
# По умолчанию (если пусто и без аргументов): assistant_api/data/raw/
# Форматы: .txt, .docx, .pdf → data/<имя>_clean.txt

